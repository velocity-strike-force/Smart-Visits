# Client visits: unset or `mock` = embedded demo data. `api` = GET /api/visit (handler reads DynamoDB only).
# Optional npm scripts (after `npm install`): `npm run dev:mock` / `npm run dev:api`

# VITE_VISITS_DATA_SOURCE=mock
# VITE_VISITS_DATA_SOURCE=api

# When using `api`, optional absolute API origin. If unset, Vite proxies /api → http://127.0.0.1:3000 (see vite.config.ts).
# VITE_API_BASE_URL=http://127.0.0.1:3000

# When using `api`, user is loaded from GET /api/profile?userId=… (defaults to user-seed-00 if unset).
# VITE_PROFILE_USER_ID=user-seed-00

# Outlook callback route is handled by the SPA at /outlook/callback.
# Make sure server `OutlookOAuthRedirectUri` points to your API
# (e.g. http://127.0.0.1:3000/api/outlook-integration) and FRONTEND_BASE_URL
# resolves to this Vite origin.
